generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum IdeaStatus {
  OPEN
  IN_PROGRESS
  SHIPPED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  password      String?      // For credential JWT fallback
  bio           String?
  githubUrl     String?
  twitterUrl    String?
  accounts      Account[]
  sessions      Session[]
  savedIdeas    SavedIdea[]
  repositories  Repository[]
  upvotes       Upvote[]
  comments      Comment[]
  waitlists     Waitlist[]
  submittedIdeas Idea[]      @relation("IdeaAuthor")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id               String       @id @default(cuid())
  title            String
  description      String
  sourceUrl        String?
  difficulty       String
  devTime          String
  domain           String
  recommendedStack String[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  status           IdeaStatus   @default(OPEN)
  embedding        Unsupported("vector(3072)")?
  
  authorId         String?
  author           User?        @relation("IdeaAuthor", fields: [authorId], references: [id])

  savedBy          SavedIdea[]
  repositories     Repository[]
  tags             IdeaTag[]
  upvotes          Upvote[]
  comments         Comment[]
  waitlist         Waitlist[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  ideas IdeaTag[]
}

model IdeaTag {
  ideaId String
  tagId  String
  idea   Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([ideaId, tagId])
}

model SavedIdea {
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  @@id([userId, ideaId])
}

model Waitlist {
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  @@id([userId, ideaId])
}

model Repository {
  id               String   @id @default(cuid())
  url              String
  userId           String
  ideaId           String
  openToCoFounders Boolean  @default(false)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea             Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}

model Upvote {
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  @@id([userId, ideaId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
}
